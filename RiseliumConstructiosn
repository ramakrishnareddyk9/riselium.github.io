<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Riselium – Constructions</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@300;400;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --pink: #ff6f91;
            --peach: #ff7f50;
            --violet: #8a2be2;
            --gold: #ffd1a4;
            --dark: #050d1a;
            --darker: #020810;
            --glass: rgba(255,255,255,0.04);
            --glass-border: rgba(255,255,255,0.1);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            background: var(--darker);
            color: #fff;
            font-family: 'Rajdhani', sans-serif;
            overflow-x: hidden;
        }

        /* ===== HEADER ===== */
        header {
            position: fixed;
            top: 0; left: 0;
            width: 100%;
            height: 72px;
            z-index: 2000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            background: rgba(2,8,16,0.92);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--glass-border);
        }
        .header-logo { display: flex; align-items: center; gap: 10px; cursor: pointer; }
        .logo-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, var(--pink), var(--violet));
            clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Bebas Neue', sans-serif; font-size: 18px;
            animation: pulse-logo 3s ease-in-out infinite;
        }
        @keyframes pulse-logo {
            0%,100% { box-shadow: 0 0 10px rgba(255,111,145,0.4); }
            50% { box-shadow: 0 0 25px rgba(255,111,145,0.8), 0 0 50px rgba(138,43,226,0.4); }
        }
        .brand-name {
            font-family: 'Bebas Neue', sans-serif; font-size: 1.9rem; letter-spacing: 4px;
            background: linear-gradient(90deg, #ff6f91, #ffd1a4, #d1c4ff, #ff7f50, #8a2be2);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .brand-sub {
            font-family: 'Rajdhani', sans-serif; font-size: 0.7rem; font-weight: 600;
            letter-spacing: 6px; color: rgba(255,255,255,0.4); text-transform: uppercase; margin-top: -4px;
        }
        nav { display: flex; align-items: center; gap: 32px; }
        nav a {
            font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 0.9rem;
            letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.6);
            text-decoration: none; transition: color 0.3s; position: relative; cursor: pointer;
        }
        nav a::after {
            content: ''; position: absolute; bottom: -2px; left: 0;
            width: 0; height: 1px; background: var(--pink); transition: width 0.3s;
        }
        nav a:hover { color: #fff; }
        nav a:hover::after, nav a.active::after { width: 100%; }
        nav a.active { color: #fff; }
        .header-actions { display: flex; align-items: center; gap: 12px; }
        .btn-outline {
            padding: 8px 22px; border: 1px solid rgba(255,111,145,0.5); border-radius: 4px;
            color: var(--pink); font-family: 'Rajdhani', sans-serif; font-weight: 700;
            font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase;
            cursor: pointer; background: transparent; transition: all 0.3s;
        }
        .btn-outline:hover { background: rgba(255,111,145,0.1); border-color: var(--pink); box-shadow: 0 0 15px rgba(255,111,145,0.3); }
        .btn-solid {
            padding: 8px 22px; border: none; border-radius: 4px;
            background: linear-gradient(135deg, var(--pink), var(--violet));
            color: #fff; font-family: 'Rajdhani', sans-serif; font-weight: 700;
            font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase;
            cursor: pointer; transition: all 0.3s; position: relative; overflow: hidden;
        }
        .btn-solid::before {
            content: ''; position: absolute; top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.4s;
        }
        .btn-solid:hover::before { left: 100%; }
        .btn-solid:hover { box-shadow: 0 0 20px rgba(255,111,145,0.5); transform: translateY(-1px); }

        /* ===== PAGE SECTIONS (SPA) ===== */
        .page-section { display: none; }
        .page-section.active { display: block; }

        /* ===== AUTH MODALS ===== */
        .modal-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,0.7); backdrop-filter: blur(8px);
            z-index: 5000; align-items: center; justify-content: center;
        }
        .modal-overlay.active { display: flex; }
        .modal-box {
            background: linear-gradient(145deg, #0d1b2e, #080f1c);
            border: 1px solid var(--glass-border); border-radius: 16px;
            padding: 40px; width: 420px; max-width: 95vw; position: relative;
            box-shadow: 0 30px 80px rgba(0,0,0,0.6), 0 0 40px rgba(255,111,145,0.1);
        }
        .modal-close {
            position: absolute; top: 16px; right: 16px;
            width: 32px; height: 32px; border-radius: 50%;
            border: 1px solid var(--glass-border); background: var(--glass);
            color: rgba(255,255,255,0.6); cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; transition: all 0.3s;
        }
        .modal-close:hover { background: rgba(255,111,145,0.2); color: var(--pink); border-color: var(--pink); }
        .modal-title {
            font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 3px;
            background: linear-gradient(90deg, var(--pink), var(--gold));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 6px;
        }
        .modal-subtitle { color: rgba(255,255,255,0.4); font-size: 0.85rem; letter-spacing: 1px; margin-bottom: 28px; }
        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
        .form-group input {
            width: 100%; padding: 12px 16px;
            background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border);
            border-radius: 8px; color: #fff; font-family: 'Rajdhani', sans-serif;
            font-size: 1rem; transition: border-color 0.3s, box-shadow 0.3s; outline: none;
        }
        .form-group input:focus { border-color: var(--pink); box-shadow: 0 0 12px rgba(255,111,145,0.2); }
        .form-submit {
            width: 100%; padding: 14px;
            background: linear-gradient(135deg, var(--pink), var(--violet));
            border: none; border-radius: 8px; color: #fff;
            font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: 3px;
            cursor: pointer; margin-top: 8px; transition: all 0.3s;
        }
        .form-submit:hover { box-shadow: 0 0 25px rgba(255,111,145,0.5); transform: translateY(-2px); }
        .modal-switch { text-align: center; margin-top: 20px; color: rgba(255,255,255,0.4); font-size: 0.9rem; }
        .modal-switch a { color: var(--pink); cursor: pointer; text-decoration: underline; }

        /* ===== HERO SECTION ===== */
        .hero {
            position: relative; width: 100%; height: 100vh;
            overflow: hidden; display: flex; align-items: center; justify-content: center;
        }
        .hero-3d-scene {
            position: absolute; inset: 0;
            background: radial-gradient(ellipse at 50% 60%, #0a1a35 0%, #020810 70%);
            display: flex; align-items: center; justify-content: center; overflow: hidden;
        }

        /* ---- DIGITAL TWIN SVG CITY ---- */
        #dt-canvas {
            position: absolute; inset: 0; width: 100%; height: 100%;
        }

        /* Grid floor */
        .grid-floor {
            position: absolute; bottom: 0; left: 0;
            width: 100%; height: 55%;
            background-image:
                linear-gradient(rgba(255,111,145,0.07) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,111,145,0.07) 1px, transparent 1px);
            background-size: 60px 60px;
            transform: perspective(500px) rotateX(62deg);
            transform-origin: bottom;
        }

        /* Building blocks */
        .building-scene {
            position: absolute; bottom: 14%; left: 50%;
            transform: translateX(-50%);
            display: flex; align-items: flex-end; gap: 10px;
            transform-style: preserve-3d;
        }
        .building-block {
            position: relative; width: 58px;
            background: linear-gradient(180deg, rgba(255,111,145,0.5) 0%, rgba(138,43,226,0.35) 60%, rgba(2,8,16,0.8) 100%);
            border: 1px solid rgba(255,111,145,0.25);
            border-radius: 3px 3px 0 0;
            animation: buildUp 3.5s cubic-bezier(0.22,0.61,0.36,1) forwards;
            transform-origin: bottom;
            box-shadow: 0 0 25px rgba(255,111,145,0.15), inset 0 0 30px rgba(255,255,255,0.02);
        }
        .building-block::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
            background: linear-gradient(90deg, transparent, var(--pink), transparent);
            box-shadow: 0 0 12px var(--pink); animation: roofGlow 2s ease-in-out infinite;
        }
        @keyframes roofGlow { 0%,100%{opacity:0.6;} 50%{opacity:1;} }
        /* Window grid */
        .building-block::after {
            content: ''; position: absolute; inset: 6px;
            background-image:
                linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
            background-size: 11px 14px;
        }

        /* random lit windows */
        .win-lights {
            position: absolute; inset: 0; overflow: hidden; border-radius: 3px 3px 0 0;
        }
        .win-light {
            position: absolute; width: 7px; height: 9px;
            background: rgba(255,230,100,0.7); border-radius: 1px;
            animation: winBlink var(--dur,3s) var(--del,0s) ease-in-out infinite;
        }
        @keyframes winBlink { 0%,100%{opacity:0.8;} 50%{opacity:0.2;} }

        .b1{height:160px;animation-delay:0s;}
        .b2{height:290px;animation-delay:.25s;width:74px;background:linear-gradient(180deg,rgba(138,43,226,0.55),rgba(255,111,145,0.3),rgba(2,8,16,0.8));}
        .b3{height:220px;animation-delay:.5s;}
        .b4{height:380px;animation-delay:.75s;width:68px;background:linear-gradient(180deg,rgba(255,209,164,0.5),rgba(138,43,226,0.35),rgba(2,8,16,0.8));}
        .b5{height:200px;animation-delay:1s;}
        .b6{height:330px;animation-delay:1.25s;width:80px;}
        .b7{height:170px;animation-delay:1.5s;}
        .b8{height:260px;animation-delay:1.75s;width:66px;background:linear-gradient(180deg,rgba(100,180,255,0.5),rgba(138,43,226,0.3),rgba(2,8,16,0.8));}
        .b9{height:140px;animation-delay:2s;}

        @keyframes buildUp { 0%{transform:scaleY(0);opacity:0;} 60%{opacity:1;} 100%{transform:scaleY(1);opacity:1;} }

        /* Crane */
        .crane { position:absolute; right:20%; bottom:14%; opacity:0; animation: craneIn 1s 2.2s ease forwards; }
        @keyframes craneIn { to{opacity:1;} }
        .crane-tower { width:6px; height:180px; background:linear-gradient(180deg,#ffd1a4,#ff7f50); margin:0 auto; box-shadow:0 0 8px rgba(255,209,164,0.4); }
        .crane-arm { position:absolute; top:10px; right:0; width:130px; height:6px; background:linear-gradient(90deg,#ffd1a4,#ff7f50); box-shadow:0 0 8px rgba(255,209,164,0.4); }
        .crane-cable { position:absolute; top:6px; right:25px; width:1px; height:0; background:rgba(255,255,255,0.5); animation:cableGrow 1s 3s forwards, cableSwing 2.5s 4s ease-in-out infinite; transform-origin:top; }
        @keyframes cableGrow { to{height:55px;} }
        @keyframes cableSwing { 0%,100%{transform:rotate(-5deg);} 50%{transform:rotate(5deg);} }
        .crane-load { position:absolute; bottom:-12px; left:-6px; width:12px; height:12px; background: var(--pink); border-radius:2px; box-shadow:0 0 8px var(--pink); }

        /* Data overlays / HUD lines */
        .hud-line {
            position: absolute; background: transparent;
            border: 1px dashed rgba(255,111,145,0.2);
            border-radius: 4px; pointer-events: none;
            animation: hudPulse 4s ease-in-out infinite;
        }
        @keyframes hudPulse { 0%,100%{border-color:rgba(255,111,145,0.15);} 50%{border-color:rgba(255,111,145,0.4);} }
        .hud-dot {
            position: absolute; width: 6px; height: 6px;
            border-radius: 50%; background: var(--pink);
            box-shadow: 0 0 10px var(--pink);
            animation: dotPulse 2s ease-in-out infinite;
        }
        @keyframes dotPulse { 0%,100%{transform:scale(1);opacity:1;} 50%{transform:scale(1.6);opacity:0.4;} }
        .hud-label {
            position: absolute; font-family: 'Orbitron', sans-serif;
            font-size: 0.55rem; color: rgba(255,111,145,0.7);
            letter-spacing: 2px; text-transform: uppercase; white-space: nowrap;
        }

        /* scan lines */
        .scan-line {
            position: absolute; left: 0; right: 0; height: 1px;
            background: linear-gradient(90deg, transparent 0%, rgba(255,111,145,0.6) 40%, rgba(138,43,226,0.6) 60%, transparent 100%);
            animation: scanDown 5s linear infinite; pointer-events: none;
        }
        @keyframes scanDown { 0%{top:0;opacity:0.8;} 100%{top:100%;opacity:0;} }

        /* Particles */
        .particle { position:absolute; border-radius:50%; animation:floatParticle linear infinite; opacity:0; }
        @keyframes floatParticle { 0%{transform:translateY(100vh) scale(0);opacity:0;} 10%{opacity:1;} 90%{opacity:0.5;} 100%{transform:translateY(-20px) scale(1.5);opacity:0;} }

        /* Hero content */
        .hero-content { position:relative; z-index:10; text-align:center; padding:0 20px; }
        .hero-tag {
            display:inline-block; padding:5px 16px;
            border:1px solid rgba(255,111,145,0.4); border-radius:100px;
            font-size:0.75rem; letter-spacing:4px; text-transform:uppercase; color:var(--pink);
            margin-bottom:24px; animation:fadeInDown 1s ease forwards; opacity:0;
        }
        .hero-title {
            font-family:'Bebas Neue',sans-serif; font-size:clamp(3.5rem,9vw,7rem);
            line-height:0.95; letter-spacing:4px; margin-bottom:20px;
            animation:fadeInDown 1s .2s ease forwards; opacity:0;
        }
        .hero-title .line1 { background:linear-gradient(90deg,#fff,rgba(255,255,255,0.7)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
        .hero-title .line2 { background:linear-gradient(90deg,var(--pink),var(--gold),var(--violet)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
        .hero-desc { font-size:1.1rem; color:rgba(255,255,255,0.5); letter-spacing:2px; margin-bottom:36px; max-width:500px; margin-left:auto; margin-right:auto; animation:fadeInDown 1s .4s ease forwards; opacity:0; }
        .hero-ctas { display:flex; gap:16px; justify-content:center; animation:fadeInDown 1s .6s ease forwards; opacity:0; }
        .cta-primary {
            padding:14px 36px; background:linear-gradient(135deg,var(--pink),var(--violet));
            border:none; border-radius:6px; color:#fff; font-family:'Rajdhani',sans-serif;
            font-weight:700; font-size:1rem; letter-spacing:3px; text-transform:uppercase;
            cursor:pointer; position:relative; overflow:hidden; transition:all .3s;
        }
        .cta-primary::before { content:''; position:absolute; top:0; left:-100%; width:100%; height:100%; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent); transition:left .5s; }
        .cta-primary:hover::before{left:100%;} .cta-primary:hover{box-shadow:0 0 30px rgba(255,111,145,0.5);transform:translateY(-2px);}
        .cta-secondary { padding:14px 36px; background:transparent; border:1px solid rgba(255,255,255,0.2); border-radius:6px; color:rgba(255,255,255,0.7); font-family:'Rajdhani',sans-serif; font-weight:700; font-size:1rem; letter-spacing:3px; text-transform:uppercase; cursor:pointer; transition:all .3s; }
        .cta-secondary:hover { border-color:var(--pink); color:#fff; background:rgba(255,111,145,0.05); }

        .stats-bar {
            position:absolute; bottom:0; left:0; right:0;
            background:rgba(2,8,16,0.8); backdrop-filter:blur(16px);
            border-top:1px solid var(--glass-border);
            display:flex; justify-content:center; gap:60px; padding:20px 40px;
        }
        .stat-item { text-align:center; }
        .stat-num { font-family:'Bebas Neue',sans-serif; font-size:2rem; background:linear-gradient(90deg,var(--pink),var(--gold)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
        .stat-label { font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.3); }

        @keyframes fadeInDown { 0%{opacity:0;transform:translateY(-20px);} 100%{opacity:1;transform:translateY(0);} }

        /* ===== SECTION WRAPPER ===== */
        .inner-section {
            min-height: 100vh;
            padding-top: 72px;
            background: linear-gradient(180deg, #020810, #050d1a);
        }
        .section-header {
            padding: 60px 60px 10px;
        }
        .section-label { font-size:0.75rem; letter-spacing:5px; text-transform:uppercase; color:var(--pink); margin-bottom:10px; }
        .section-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(2.5rem,5vw,4rem); letter-spacing:3px; margin-bottom:10px; background:linear-gradient(90deg,#fff,rgba(255,255,255,0.5)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
        .section-desc { color:rgba(255,255,255,0.45); font-size:1rem; letter-spacing:1px; max-width:600px; margin-bottom:50px; }

        /* ===== PROJECTS SECTION ===== */
        #projects-section { background: linear-gradient(180deg, #020810, #050d1a); }
        .projects-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:28px; padding:0 60px 80px; }
        .project-card {
            background:linear-gradient(145deg,#0d1b2e,#060e1a);
            border:1px solid rgba(255,255,255,0.07); border-radius:14px; overflow:hidden;
            cursor:pointer; transition:all 0.35s; position:relative;
        }
        .project-card:hover { transform:translateY(-6px); border-color:rgba(255,111,145,0.3); box-shadow:0 20px 50px rgba(0,0,0,0.5), 0 0 30px rgba(255,111,145,0.1); }
        .project-card-img {
            height: 200px; overflow: hidden; position: relative;
            background: linear-gradient(135deg, #0a1520, #150820);
            display: flex; align-items: center; justify-content: center;
        }
        .project-card-img img { width:100%; height:100%; object-fit:cover; transition:transform 0.4s; }
        .project-card:hover .project-card-img img { transform:scale(1.06); }
        .project-card-img .placeholder-icon { font-size:4rem; opacity:0.3; }
        .project-badge {
            position:absolute; top:12px; left:12px;
            padding:4px 12px; border-radius:100px; font-size:0.7rem; letter-spacing:2px;
            text-transform:uppercase; font-weight:700;
        }
        .badge-res { background:rgba(255,111,145,0.2); color:var(--pink); border:1px solid rgba(255,111,145,0.3); }
        .badge-com { background:rgba(255,127,80,0.2); color:var(--peach); border:1px solid rgba(255,127,80,0.3); }
        .badge-ind { background:rgba(138,43,226,0.2); color:#b06aff; border:1px solid rgba(138,43,226,0.3); }
        .badge-land { background:rgba(100,220,100,0.2); color:#6de06d; border:1px solid rgba(100,220,100,0.3); }
        .project-card-body { padding:20px; }
        .project-card-title { font-family:'Bebas Neue',sans-serif; font-size:1.5rem; letter-spacing:2px; margin-bottom:8px; }
        .project-card-desc { color:rgba(255,255,255,0.45); font-size:0.9rem; line-height:1.6; margin-bottom:16px; }
        .project-card-meta { display:flex; gap:16px; }
        .project-meta-item { font-size:0.75rem; letter-spacing:1px; color:rgba(255,255,255,0.3); }
        .project-meta-item span { color:rgba(255,255,255,0.6); }
        .project-view-btn {
            display:inline-flex; align-items:center; gap:8px; margin-top:16px;
            padding:8px 20px; background:transparent; border:1px solid rgba(255,111,145,0.3);
            border-radius:6px; color:var(--pink); font-family:'Rajdhani',sans-serif;
            font-weight:700; font-size:0.85rem; letter-spacing:2px; text-transform:uppercase;
            cursor:pointer; transition:all 0.3s;
        }
        .project-view-btn:hover { background:rgba(255,111,145,0.1); border-color:var(--pink); }

        /* Project Detail Modal */
        .project-modal-overlay {
            display:none; position:fixed; inset:0;
            background:rgba(0,0,0,0.85); backdrop-filter:blur(12px);
            z-index:6000; align-items:center; justify-content:center; padding:20px;
        }
        .project-modal-overlay.active { display:flex; }
        .project-modal {
            background:linear-gradient(145deg,#0a1828,#050d1a);
            border:1px solid rgba(255,111,145,0.15); border-radius:20px;
            width:900px; max-width:98vw; max-height:90vh; overflow-y:auto;
            position:relative; box-shadow:0 40px 100px rgba(0,0,0,0.7);
        }
        .project-modal::-webkit-scrollbar { width:4px; }
        .project-modal::-webkit-scrollbar-thumb { background:rgba(255,111,145,0.3); border-radius:2px; }
        .project-modal-close {
            position:sticky; top:16px; float:right; margin:16px 16px 0 0;
            width:36px; height:36px; border-radius:50%;
            border:1px solid var(--glass-border); background:rgba(0,0,0,0.5);
            color:rgba(255,255,255,0.6); cursor:pointer;
            display:flex; align-items:center; justify-content:center;
            font-size:1rem; transition:all 0.3s; z-index:10;
        }
        .project-modal-close:hover { background:rgba(255,111,145,0.2); color:var(--pink); border-color:var(--pink); }
        .project-modal-hero {
            height:300px; background:linear-gradient(135deg,#0a1520,#150820);
            display:flex; align-items:center; justify-content:center;
            border-radius:20px 20px 0 0; overflow:hidden; position:relative;
        }
        .project-modal-hero img { width:100%; height:100%; object-fit:cover; }
        .project-modal-hero .no-img { font-size:6rem; opacity:0.2; }
        .project-modal-body { padding:36px; }
        .project-modal-tag { display:inline-block; padding:4px 14px; border-radius:100px; font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; margin-bottom:14px; }
        .project-modal-title { font-family:'Bebas Neue',sans-serif; font-size:2.8rem; letter-spacing:3px; margin-bottom:12px; line-height:1; }
        .project-modal-desc { color:rgba(255,255,255,0.55); font-size:1rem; line-height:1.8; margin-bottom:28px; }
        .project-modal-specs {
            display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:28px;
        }
        .spec-card { background:rgba(255,255,255,0.03); border:1px solid var(--glass-border); border-radius:10px; padding:16px; }
        .spec-card-label { font-size:0.7rem; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.3); margin-bottom:6px; }
        .spec-card-val { font-family:'Bebas Neue',sans-serif; font-size:1.4rem; letter-spacing:2px; }

        /* Image gallery */
        .project-gallery { margin-bottom:28px; }
        .project-gallery-title { font-family:'Bebas Neue',sans-serif; font-size:1.3rem; letter-spacing:2px; margin-bottom:14px; color:rgba(255,255,255,0.7); }
        .gallery-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:10px; }
        .gallery-thumb {
            height:120px; background:rgba(255,255,255,0.04);
            border:1px solid var(--glass-border); border-radius:8px;
            overflow:hidden; cursor:pointer; transition:all 0.3s;
            display:flex; align-items:center; justify-content:center;
        }
        .gallery-thumb:hover { border-color:rgba(255,111,145,0.4); transform:scale(1.02); }
        .gallery-thumb img { width:100%; height:100%; object-fit:cover; }
        .gallery-thumb .thumb-placeholder { font-size:2rem; opacity:0.3; }

        /* Upload area */
        .upload-area {
            border: 2px dashed rgba(255,111,145,0.25); border-radius:12px;
            padding:30px; text-align:center; margin-bottom:24px;
            background:rgba(255,111,145,0.03); transition:all 0.3s; cursor:pointer;
        }
        .upload-area:hover, .upload-area.drag-over { border-color:rgba(255,111,145,0.6); background:rgba(255,111,145,0.07); }
        .upload-icon { font-size:2rem; margin-bottom:8px; }
        .upload-title { font-family:'Bebas Neue',sans-serif; font-size:1.2rem; letter-spacing:2px; margin-bottom:4px; }
        .upload-sub { color:rgba(255,255,255,0.35); font-size:0.8rem; letter-spacing:1px; }
        .upload-btn {
            display:inline-block; margin-top:12px; padding:8px 20px;
            background:linear-gradient(135deg,var(--pink),var(--violet));
            border:none; border-radius:6px; color:#fff;
            font-family:'Rajdhani',sans-serif; font-weight:700; font-size:0.85rem;
            letter-spacing:2px; cursor:pointer; transition:all 0.3s;
        }
        .upload-btn:hover { box-shadow:0 0 15px rgba(255,111,145,0.4); }

        /* Text editor area */
        .project-notes-area {
            background:rgba(255,255,255,0.03); border:1px solid var(--glass-border);
            border-radius:10px; padding:16px; min-height:120px;
            color:rgba(255,255,255,0.7); font-family:'Rajdhani',sans-serif;
            font-size:0.95rem; line-height:1.7; resize:vertical;
            width:100%; outline:none; transition:border-color 0.3s;
        }
        .project-notes-area:focus { border-color:rgba(255,111,145,0.4); }
        .save-notes-btn {
            margin-top:10px; padding:8px 24px;
            background:linear-gradient(135deg,var(--pink),var(--violet));
            border:none; border-radius:6px; color:#fff;
            font-family:'Rajdhani',sans-serif; font-weight:700; font-size:0.85rem;
            letter-spacing:2px; cursor:pointer; transition:all 0.3s;
        }
        .save-notes-btn:hover { box-shadow:0 0 15px rgba(255,111,145,0.4); }
        .save-success { color:#4ade80; font-size:0.8rem; margin-left:10px; opacity:0; transition:opacity 0.3s; }

        /* ===== SERVICES SECTION ===== */
        #services-section { background:linear-gradient(180deg,#020810,#050d1a); }
        .services-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:24px; padding:0 60px 80px; }
        .service-card {
            background:linear-gradient(145deg,#0d1b2e,#060e1a);
            border:1px solid rgba(255,255,255,0.07); border-radius:14px; padding:36px 28px;
            transition:all 0.35s; position:relative; overflow:hidden;
        }
        .service-card::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg,rgba(255,111,145,0.04),transparent); opacity:0; transition:opacity 0.3s; }
        .service-card:hover::before { opacity:1; }
        .service-card:hover { transform:translateY(-6px); border-color:rgba(255,111,145,0.25); box-shadow:0 20px 50px rgba(0,0,0,0.5); }
        .service-icon { font-size:2.8rem; margin-bottom:16px; display:block; }
        .service-title { font-family:'Bebas Neue',sans-serif; font-size:1.6rem; letter-spacing:2px; margin-bottom:10px; }
        .service-desc { color:rgba(255,255,255,0.45); font-size:0.9rem; line-height:1.7; margin-bottom:20px; }
        .service-features { list-style:none; }
        .service-features li { color:rgba(255,255,255,0.5); font-size:0.85rem; padding:5px 0; border-bottom:1px solid rgba(255,255,255,0.05); display:flex; align-items:center; gap:8px; }
        .service-features li::before { content:'▸'; color:var(--pink); flex-shrink:0; }
        .service-price { margin-top:20px; font-family:'Bebas Neue',sans-serif; font-size:1.4rem; letter-spacing:2px; background:linear-gradient(90deg,var(--pink),var(--gold)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }

        /* ===== ABOUT SECTION ===== */
        #about-section { background:linear-gradient(180deg,#020810,#050d1a); }
        .about-inner { padding:40px 60px 80px; display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:start; }
        /* .about-left {} */
        .about-text { color:rgba(255,255,255,0.55); font-size:1rem; line-height:1.9; margin-bottom:24px; }
        .about-values { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:30px; }
        .value-card { background:rgba(255,255,255,0.03); border:1px solid var(--glass-border); border-radius:10px; padding:20px; }
        .value-icon { font-size:1.8rem; margin-bottom:8px; }
        .value-title { font-family:'Bebas Neue',sans-serif; font-size:1.1rem; letter-spacing:2px; margin-bottom:4px; }
        .value-desc { font-size:0.8rem; color:rgba(255,255,255,0.35); letter-spacing:1px; }
        /* .about-right {} */
        .team-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
        .team-card { background:linear-gradient(145deg,#0d1b2e,#060e1a); border:1px solid rgba(255,255,255,0.07); border-radius:12px; padding:24px; text-align:center; transition:all 0.3s; }
        .team-card:hover { border-color:rgba(255,111,145,0.25); transform:translateY(-4px); }
        .team-avatar { width:70px; height:70px; border-radius:50%; background:linear-gradient(135deg,var(--pink),var(--violet)); display:flex; align-items:center; justify-content:center; font-size:2rem; margin:0 auto 14px; }
        .team-name { font-family:'Bebas Neue',sans-serif; font-size:1.2rem; letter-spacing:2px; margin-bottom:4px; }
        .team-role { font-size:0.75rem; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.35); }
        .milestones { margin-top:40px; }
        .milestone { display:flex; gap:16px; margin-bottom:20px; align-items:flex-start; }
        .milestone-year { font-family:'Bebas Neue',sans-serif; font-size:1.3rem; color:var(--pink); letter-spacing:2px; min-width:60px; }
        .milestone-text { color:rgba(255,255,255,0.5); font-size:0.9rem; line-height:1.6; }

        /* ===== CONTACT SECTION ===== */
        #contact-section { background:linear-gradient(180deg,#020810,#050d1a); }
        .contact-inner { padding:40px 60px 80px; display:grid; grid-template-columns:1fr 1fr; gap:60px; }
        /* .contact-info {} */
        .contact-info-item { display:flex; gap:16px; align-items:flex-start; margin-bottom:28px; }
        .contact-icon { width:48px; height:48px; border-radius:10px; background:rgba(255,111,145,0.1); border:1px solid rgba(255,111,145,0.2); display:flex; align-items:center; justify-content:center; font-size:1.3rem; flex-shrink:0; }
        .contact-info-label { font-size:0.75rem; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.3); margin-bottom:4px; }
        .contact-info-val { color:rgba(255,255,255,0.8); font-size:1rem; letter-spacing:1px; }
        .contact-form-card { background:linear-gradient(145deg,#0d1b2e,#060e1a); border:1px solid rgba(255,255,255,0.07); border-radius:16px; padding:36px; }
        .contact-form-title { font-family:'Bebas Neue',sans-serif; font-size:1.8rem; letter-spacing:2px; margin-bottom:24px; }
        .cf-group { margin-bottom:18px; }
        .cf-group label { display:block; font-size:0.75rem; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.4); margin-bottom:8px; }
        .cf-group input, .cf-group textarea, .cf-group select {
            width:100%; padding:12px 16px;
            background:rgba(255,255,255,0.04); border:1px solid var(--glass-border);
            border-radius:8px; color:#fff; font-family:'Rajdhani',sans-serif; font-size:0.95rem;
            outline:none; transition:border-color 0.3s; resize:vertical;
        }
        .cf-group select option { background:#0d1b2e; }
        .cf-group input:focus, .cf-group textarea:focus, .cf-group select:focus { border-color:rgba(255,111,145,0.4); }
        .cf-submit { width:100%; padding:14px; background:linear-gradient(135deg,var(--pink),var(--violet)); border:none; border-radius:8px; color:#fff; font-family:'Bebas Neue',sans-serif; font-size:1.3rem; letter-spacing:3px; cursor:pointer; transition:all 0.3s; margin-top:8px; }
        .cf-submit:hover { box-shadow:0 0 25px rgba(255,111,145,0.5); transform:translateY(-2px); }

        /* ===== LAYOUTS CARDS SECTION ===== */
        .layouts-section { padding:100px 60px; background:linear-gradient(180deg,#020810,#050d1a); }
        .cards-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(270px,1fr)); gap:24px; }
        .flip-card { height:340px; perspective:1000px; cursor:pointer; }
        .flip-card-inner { position:relative; width:100%; height:100%; text-align:center; transition:transform 0.9s cubic-bezier(0.4,0.2,0.2,1); transform-style:preserve-3d; }
        .flip-card:hover .flip-card-inner { transform:rotateY(180deg); }
        .flip-card-front,.flip-card-back { position:absolute; width:100%; height:100%; backface-visibility:hidden; border-radius:12px; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:30px; border:1px solid rgba(255,255,255,0.06); overflow:hidden; }
        .flip-card-front::before { content:''; position:absolute; inset:0; background-image:linear-gradient(rgba(255,255,255,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.03) 1px,transparent 1px); background-size:30px 30px; }
        .card-1-front{background:linear-gradient(135deg,#1a0820,#300a50);}
        .card-2-front{background:linear-gradient(135deg,#1a0a08,#3d1500);}
        .card-3-front{background:linear-gradient(135deg,#080a1a,#10194a);}
        .card-4-front{background:linear-gradient(135deg,#1a1208,#3d2a00);}
        .card-icon { font-size:3rem; margin-bottom:16px; filter:drop-shadow(0 0 15px rgba(255,111,145,0.5)); }
        .flip-card-front h2 { font-family:'Bebas Neue',sans-serif; font-size:1.8rem; letter-spacing:3px; margin-bottom:8px; }
        .flip-card-front p { font-size:0.85rem; letter-spacing:2px; color:rgba(255,255,255,0.5); text-transform:uppercase; }
        .card-glow { position:absolute; width:150px; height:150px; border-radius:50%; filter:blur(50px); opacity:0.3; bottom:-30px; right:-30px; }
        .glow-1{background:var(--violet);} .glow-2{background:var(--peach);} .glow-3{background:#4040ff;} .glow-4{background:var(--gold);}
        .flip-card-back { background:linear-gradient(145deg,#0d1b2e,#050d1a); transform:rotateY(180deg); border-color:rgba(255,111,145,0.2); gap:12px; }
        .flip-card-back h2 { font-family:'Bebas Neue',sans-serif; font-size:1.6rem; letter-spacing:3px; margin-bottom:8px; background:linear-gradient(90deg,var(--pink),var(--gold)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
        .flip-card-back p { color:rgba(255,255,255,0.6); line-height:1.7; font-size:0.95rem; }
        .card-detail-btn {
            display:inline-flex; align-items:center; gap:6px; padding:8px 20px;
            border:1px solid rgba(255,111,145,0.4); border-radius:100px;
            color:var(--pink); font-family:'Rajdhani',sans-serif; font-weight:700;
            font-size:0.8rem; letter-spacing:2px; text-transform:uppercase;
            cursor:pointer; background:transparent; transition:all 0.3s; margin-top:8px;
        }
        .card-detail-btn:hover { background:rgba(255,111,145,0.1); border-color:var(--pink); }

        /* ===== FOOTER ===== */
        footer { background:#020810; border-top:1px solid var(--glass-border); padding:60px 60px 40px; position:relative; }
        .footer-grid { display:grid; grid-template-columns:1.5fr 1fr 1fr 1fr; gap:40px; margin-bottom:50px; }
        .footer-brand .brand-name { font-size:2rem; margin-bottom:8px; display:block; }
        .footer-brand p { color:rgba(255,255,255,0.4); font-size:0.9rem; line-height:1.7; margin-bottom:24px; }
        .social-row { display:flex; gap:10px; }
        .social-btn { width:40px; height:40px; border-radius:50%; border:1px solid var(--glass-border); background:var(--glass); display:flex; align-items:center; justify-content:center; transition:all 0.3s; text-decoration:none; }
        .social-btn:hover { border-color:var(--pink); background:rgba(255,111,145,0.1); transform:translateY(-3px); box-shadow:0 6px 15px rgba(255,111,145,0.2); }
        .social-btn img { width:18px; height:18px; filter:brightness(0.7); }
        .social-btn:hover img { filter:brightness(1); }
        .footer-col h4 { font-family:'Bebas Neue',sans-serif; letter-spacing:3px; font-size:1.1rem; color:rgba(255,255,255,0.7); margin-bottom:20px; }
        .footer-col a { display:block; color:rgba(255,255,255,0.4); text-decoration:none; font-size:0.9rem; margin-bottom:10px; transition:color 0.3s; letter-spacing:1px; }
        .footer-col a:hover { color:var(--pink); }
        .footer-bottom { border-top:1px solid var(--glass-border); padding-top:24px; display:flex; justify-content:space-between; align-items:center; }
        .footer-copyright { color:rgba(255,255,255,0.3); font-size:0.85rem; letter-spacing:1px; }
        .footer-legal { display:flex; gap:24px; }
        .footer-legal a { color:rgba(255,255,255,0.3); text-decoration:none; font-size:0.8rem; letter-spacing:1px; transition:color 0.3s; }
        .footer-legal a:hover { color:var(--pink); }

        /* ===== CHATBOT ===== */
        .chatbot-fab {
            position:fixed; bottom:30px; right:30px; width:58px; height:58px;
            border-radius:50%; background:linear-gradient(135deg,var(--pink),var(--violet));
            border:none; cursor:pointer; display:flex; align-items:center; justify-content:center;
            z-index:3000; box-shadow:0 4px 20px rgba(255,111,145,0.4); transition:all 0.3s;
            animation:fabPulse 3s ease-in-out infinite;
        }
        @keyframes fabPulse { 0%,100%{box-shadow:0 4px 20px rgba(255,111,145,0.4);} 50%{box-shadow:0 4px 30px rgba(255,111,145,0.7),0 0 0 8px rgba(255,111,145,0.1);} }
        .chatbot-fab:hover { transform:scale(1.1); box-shadow:0 6px 30px rgba(255,111,145,0.6); }
        .chatbot-fab img { width:28px; height:28px; filter:brightness(2); }
        .chatbot-window {
            display:none; position:fixed; bottom:102px; right:30px;
            width:370px; height:500px;
            background:linear-gradient(145deg,#0a1520,#050d1a);
            border:1px solid rgba(255,111,145,0.2); border-radius:20px;
            z-index:3000; flex-direction:column; overflow:hidden;
            box-shadow:0 20px 60px rgba(0,0,0,0.6),0 0 40px rgba(255,111,145,0.1);
            animation:slideInChat 0.3s ease;
        }
        .chatbot-window.open { display:flex; }
        @keyframes slideInChat { 0%{opacity:0;transform:translateY(20px) scale(0.95);} 100%{opacity:1;transform:translateY(0) scale(1);} }
        .chatbot-header { background:linear-gradient(135deg,rgba(255,111,145,0.15),rgba(138,43,226,0.15)); border-bottom:1px solid rgba(255,111,145,0.15); padding:16px 20px; display:flex; align-items:center; gap:12px; }
        .chatbot-avatar { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,var(--pink),var(--violet)); display:flex; align-items:center; justify-content:center; font-size:1rem; }
        .chatbot-header-info h3 { font-family:'Rajdhani',sans-serif; font-weight:700; font-size:1rem; letter-spacing:2px; }
        .chatbot-header-info span { font-size:0.75rem; color:#4ade80; letter-spacing:1px; }
        .chatbot-close { margin-left:auto; width:30px; height:30px; border-radius:50%; border:1px solid var(--glass-border); background:var(--glass); color:rgba(255,255,255,0.6); cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:0.9rem; transition:all 0.3s; }
        .chatbot-close:hover { background:rgba(255,111,145,0.2); color:var(--pink); border-color:var(--pink); }
        .chatbot-messages { flex:1; padding:20px; overflow-y:auto; display:flex; flex-direction:column; gap:14px; }
        .chatbot-messages::-webkit-scrollbar { width:4px; }
        .chatbot-messages::-webkit-scrollbar-thumb { background:rgba(255,111,145,0.3); border-radius:2px; }
        .msg { display:flex; gap:10px; max-width:88%; animation:msgIn 0.3s ease; }
        @keyframes msgIn { 0%{opacity:0;transform:translateY(8px);} 100%{opacity:1;transform:translateY(0);} }
        .msg.bot { align-self:flex-start; }
        .msg.user { align-self:flex-end; flex-direction:row-reverse; }
        .msg-bubble { padding:10px 14px; border-radius:14px; font-size:0.9rem; line-height:1.5; }
        .msg.bot .msg-bubble { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.85); border-radius:4px 14px 14px 14px; }
        .msg.user .msg-bubble { background:linear-gradient(135deg,var(--pink),var(--violet)); color:#fff; border-radius:14px 4px 14px 14px; }
        .msg-avatar { width:28px; height:28px; border-radius:50%; background:linear-gradient(135deg,var(--pink),var(--violet)); display:flex; align-items:center; justify-content:center; font-size:0.8rem; flex-shrink:0; margin-top:2px; }
        .typing-indicator { display:flex; gap:4px; align-items:center; padding:10px 14px; }
        .typing-dot { width:6px; height:6px; border-radius:50%; background:rgba(255,111,145,0.6); animation:typingBounce 1.2s ease-in-out infinite; }
        .typing-dot:nth-child(2){animation-delay:.2s;} .typing-dot:nth-child(3){animation-delay:.4s;}
        @keyframes typingBounce { 0%,80%,100%{transform:translateY(0);} 40%{transform:translateY(-6px);} }
        .chatbot-quick-replies { display:flex; flex-wrap:wrap; gap:8px; padding:0 20px 12px; }
        .quick-reply { padding:5px 12px; border:1px solid rgba(255,111,145,0.3); border-radius:100px; font-size:0.75rem; color:var(--pink); cursor:pointer; background:transparent; font-family:'Rajdhani',sans-serif; letter-spacing:1px; transition:all 0.3s; }
        .quick-reply:hover { background:rgba(255,111,145,0.1); border-color:var(--pink); }
        .chatbot-input-row { display:flex; gap:10px; padding:14px 20px; border-top:1px solid rgba(255,255,255,0.06); background:rgba(0,0,0,0.2); }
        .chatbot-input-row input { flex:1; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:24px; padding:10px 16px; color:#fff; font-family:'Rajdhani',sans-serif; font-size:0.9rem; outline:none; transition:border-color 0.3s; }
        .chatbot-input-row input:focus { border-color:rgba(255,111,145,0.4); }
        .chatbot-input-row input::placeholder { color:rgba(255,255,255,0.25); }
        .chatbot-send { width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg,var(--pink),var(--violet)); border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:1rem; transition:all 0.3s; flex-shrink:0; }
        .chatbot-send:hover { transform:scale(1.1); box-shadow:0 4px 15px rgba(255,111,145,0.4); }
        .fab-badge { position:absolute; top:-4px; right:-4px; width:18px; height:18px; background:#ff4444; border-radius:50%; font-size:0.65rem; display:flex; align-items:center; justify-content:center; font-weight:bold; border:2px solid var(--darker); }

        @media(max-width:900px) {
            nav { display:none; }
            .footer-grid { grid-template-columns:1fr 1fr; }
            .stats-bar { gap:30px; flex-wrap:wrap; }
            .about-inner, .contact-inner { grid-template-columns:1fr; }
            .projects-grid { padding:0 20px 60px; }
            .services-grid { padding:0 20px 60px; }
            .layouts-section { padding:60px 20px; }
            .section-header { padding:40px 20px 10px; }
        }
        @media(max-width:600px) {
            header { padding:0 20px; }
            .chatbot-window { width:calc(100vw - 20px); right:10px; }
