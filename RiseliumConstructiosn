            { label: 'Workers', val: '2,000+' }
        ]
    },
    landscape: {
        icon: '🌿', title: 'Verdant Gardens', tag: 'Landscape', tagClass: 'badge-land',
        desc: 'A 12,000 sq.ft biophilic landscape project for a premium gated community. Includes a Japanese zen garden, native tree canopy walk, rainwater harvesting pond, therapeutic herb garden, and seasonal floral installations.',
        specs: [
            { label: 'Total Area', val: '12,000 sq.ft' },
