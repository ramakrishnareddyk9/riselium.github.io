<script>
/* ===== PARTICLES ===== */
const scene = document.getElementById('hero-scene');
for (let i = 0; i < 30; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    p.style.cssText = `left:${Math.random()*100}%;width:${Math.random()*4+1}px;height:${Math.random()*4+1}px;background:${Math.random()>.5?'#ff6f91':'#8a2be2'};animation-duration:${Math.random()*7+4}s;animation-delay:${Math.random()*6}s;`;
    scene.appendChild(p);
}

/* ===== RANDOM WINDOW LIGHTS ===== */
for (let b = 1; b <= 9; b++) {
    const container = document.getElementById('wl'+b);
    if (!container) continue;
    const parent = container.parentElement;
    const h = parseInt(parent.style.height || parent.className.match(/b\d/)?.[0]?.replace('b','') || 200);
    const count = Math.floor(Math.random() * 8) + 4;
    for (let w = 0; w < count; w++) {
        const light = document.createElement('div');
        light.className = 'win-light';
        light.style.cssText = `left:${8+Math.random()*70}%;top:${5+Math.random()*80}%;--dur:${2+Math.random()*4}s;--del:${Math.random()*3}s;`;
        container.appendChild(light);
    }
}

/* ===== SECTION NAVIGATION ===== */
const sections = ['home','projects','services','about','contact'];
function showSection(name) {
    sections.forEach(s => {
        const sec = document.getElementById(s+'-section');
        const navLink = document.getElementById('nav-'+s);
        if (sec) sec.classList.toggle('active', s === name);
        if (navLink) navLink.classList.toggle('active', s === name);
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

/* ===== AUTH MODALS ===== */
function openModal(id) { document.getElementById(id).classList.add('active'); document.body.style.overflow = 'hidden'; }
function closeModal(id) { document.getElementById(id).classList.remove('active'); document.body.style.overflow = ''; }
function switchModal(a, b) { closeModal(a); setTimeout(() => openModal(b), 150); }
document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', e => { if (e.target===o) closeModal(o.id); }));

function handleLogin() {
    const email = document.getElementById('login-email').value;
    const pass = document.getElementById('login-pass').value;
    if (!email || !pass) { alert('Please fill in all fields.'); return; }
    alert(`✅ Welcome back! Logged in as ${email}`);
    closeModal('login-modal');
}
function handleSignup() {
    const name = document.getElementById('signup-name').value;
    const email = document.getElementById('signup-email').value;
    const pass = document.getElementById('signup-pass').value;
    if (!name || !email || !pass) { alert('Please fill in all fields.'); return; }
    if (pass.length < 6) { alert('Password must be at least 6 characters.'); return; }
    alert(`🎉 Account created! Welcome to Riselium, ${name}!`);
    closeModal('signup-modal');
}
function handleContact() {
    const name = document.getElementById('cf-name').value;
    const email = document.getElementById('cf-email').value;
    if (!name || !email) { alert('Please fill in your name and email.'); return; }
    alert(`✅ Thank you, ${name}! We've received your message and will contact you within 24 hours.`);
    ['cf-name','cf-email','cf-phone','cf-type','cf-message'].forEach(id => { document.getElementById(id).value = ''; });
}

/* ===== PROJECT MODAL DATA ===== */
const projectData = {
    residential: {
        icon: '🏠', title: 'Skyline Residences', tag: 'Residential', tagClass: 'badge-res',
        desc: 'A premium residential complex featuring modern 3BHK apartments with panoramic city views, integrated smart home systems, EV charging stations, and meticulously landscaped common areas. Built using certified sustainable materials with a GRIHA 4-star rating.',
        specs: [
            { label: 'Total Area', val: '4,200 sq.ft' },
            { label: 'Floors', val: '24 Floors' },
            { label: 'Units', val: '96 Apts' },
            { label: 'Timeline', val: '28 Months' },
            { label: 'Completed', val: '2024' },
            { label: 'Rating', val: 'GRIHA ★★★★' }
        ]
    }, /*title: 'Nexus Tower'*/
    commercial: {
        icon: '🏢', title: 'Kandi Heights', tag: 'Commercial', tagClass: 'badge-com',
        desc: 'A 32-floor Grade-A commercial tower housing Fortune 500 tenants. Features flexible floor plates, a sky lobby on the 16th floor, LEED Platinum certification, and a podium-level retail arcade. Delivered 3 months ahead of schedule.',
