            { label: 'Certification', val: 'IGBC Green' }
        ]
    }
};

// Per-project gallery state
const projectGalleries = { residential:[], commercial:[], industrial:[], landscape:[] };
const projectNotes = { residential:'', commercial:'', industrial:'', landscape:'' };
let currentProject = null;

function openProjectModal(type) {
    currentProject = type;
    const data = projectData[type];
    if (!data) return;

    // Set hero
    document.getElementById('pm-hero-icon').textContent = data.icon;
    document.getElementById('pm-hero-img').style.display = 'none';
    document.getElementById('pm-hero-icon').style.display = 'block';

    // Tag
    const tag = document.getElementById('pm-tag');
    tag.textContent = data.tag;
    tag.className = 'project-modal-tag ' + data.tagClass;

    // Title & desc
    document.getElementById('pm-title').textContent = data.title;
    document.getElementById('pm-desc').textContent = data.desc;

    // Specs
    const specsEl = document.getElementById('pm-specs');
    specsEl.innerHTML = data.specs.map(s => `
        <div class="spec-card">
            <div class="spec-card-label">${s.label}</div>
            <div class="spec-card-val">${s.val}</div>
        </div>`).join('');

    // Gallery
    renderGallery(type);

    // Notes
    document.getElementById('project-notes').value = projectNotes[type] || '';

    document.getElementById('project-modal-overlay').classList.add('active');
    document.body.style.overflow = 'hidden';
}

function renderGallery(type) {
    const gallery = document.getElementById('pm-gallery');
    const images = projectGalleries[type] || [];
    gallery.innerHTML = images.map((src, i) => `
        <div class="gallery-thumb" onclick="viewFullImage('${src}')">
            <img src="${src}" alt="Project image ${i+1}">
        </div>`).join('');
    if (images.length === 0) {
        gallery.innerHTML = '<div style="color:rgba(255,255,255,0.25);font-size:0.85rem;letter-spacing:1px;padding:10px 0;">No images yet — upload below.</div>';
    }
}

function viewFullImage(src) {
    const overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.9);z-index:9999;display:flex;align-items:center;justify-content:center;cursor:zoom-out;';
    overlay.innerHTML = `<img src="${src}" style="max-width:90vw;max-height:90vh;border-radius:10px;box-shadow:0 20px 60px rgba(0,0,0,0.8);">`;
    overlay.onclick = () => overlay.remove();
    document.body.appendChild(overlay);
}

function closeProjectModal() {
    document.getElementById('project-modal-overlay').classList.remove('active');
    document.body.style.overflow = '';
    currentProject = null;
}

document.getElementById('project-modal-overlay').addEventListener('click', function(e) {
    if (e.target === this) closeProjectModal();
});

/* Drag & Drop */
const uploadArea = document.getElementById('upload-area');
uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('drag-over'); });
uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('drag-over'));
uploadArea.addEventListener('drop', e => {
    e.preventDefault();
    uploadArea.classList.remove('drag-over');
    handleFiles(e.dataTransfer.files);
});

function handleImageUpload(e) { handleFiles(e.target.files); }

function handleFiles(files) {
    if (!currentProject) return;
    Array.from(files).forEach(file => {
        if (!file.type.startsWith('image/')) return;
        const reader = new FileReader();
        reader.onload = ev => {
            projectGalleries[currentProject].push(ev.target.result);
            renderGallery(currentProject);
        };
        reader.readAsDataURL(file);
    });
}

function saveNotes() {
    if (!currentProject) return;
    projectNotes[currentProject] = document.getElementById('project-notes').value;
    const msg = document.getElementById('save-success');
    msg.style.opacity = '1';
    setTimeout(() => { msg.style.opacity = '0'; }, 2000);
}

/* ===== CHATBOT ===== */
let chatOpen = false;
const CLAUDE_API_URL = 'https://api.anthropic.com/v1/messages';

function toggleChat() {
    chatOpen = !chatOpen;
    const win = document.getElementById('chatbot-window');
    const badge = document.getElementById('fab-badge');
    win.classList.toggle('open', chatOpen);
    if (chatOpen) badge.style.display = 'none';
}
function handleKey(e) { if (e.key === 'Enter') sendMessage(); }
function sendQuick(text) { document.getElementById('chat-input').value = text; sendMessage(); }

function addMsg(role, text) {
    const msgs = document.getElementById('chatbot-messages');
    const div = document.createElement('div');
    div.className = `msg ${role}`;
    div.innerHTML = role === 'bot'
        ? `<div class="msg-avatar">🤖</div><div class="msg-bubble">${text.replace(/\n/g,'<br>')}</div>`
        : `<div class="msg-bubble">${text}</div>`;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
}

function showTyping() {
    const msgs = document.getElementById('chatbot-messages');
    const div = document.createElement('div');
    div.className = 'msg bot'; div.id = 'typing-indicator';
    div.innerHTML = `<div class="msg-avatar">🤖</div><div class="msg-bubble typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>`;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
}
function removeTyping() { const el = document.getElementById('typing-indicator'); if (el) el.remove(); }

const conversationHistory = [];

async function sendMessage() {
    const input = document.getElementById('chat-input');
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    addMsg('user', text);
    document.getElementById('quick-replies').style.display = 'none';
    showTyping();
    conversationHistory.push({ role: 'user', content: text });

    try {
        const response = await fetch(CLAUDE_API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                model: 'claude-sonnet-4-20250514',
                max_tokens: 1000,
                system: `You are an AI assistant for Riselium Constructions — a premium construction and design company based in Hyderabad, India.
Be helpful, professional, and concise. Help customers with:
- Inquiries about services: Residential (from ₹45L), Commercial (from ₹2Cr), Industrial (from ₹80L), Landscape (from ₹8L), Renovations (from ₹12L), Digital Twin/BIM (from ₹5L)
- Getting quotes (ask for project type, location, size, budget range, timeline)
- Portfolio: 100+ projects, 18+ years, 99% satisfaction
- Scheduling consultations or site visits
- General construction, architecture, BIM questions
- Contact: Phone: +1 234 567 890, Email: info@riselium.com, Address: 123 Dream Street, Hyderabad, Telangana
- Hours: Mon-Sat 9AM-7PM IST
Keep responses brief and warm. Use line breaks for clarity. Use emojis occasionally.`,
                messages: conversationHistory
            })
        });
        const data = await response.json();
        removeTyping();
        const reply = data.content?.[0]?.text || "I couldn't process that. Please call us at +1 234 567 890.";
        addMsg('bot', reply);
        conversationHistory.push({ role: 'assistant', content: reply });
    } catch (err) {
        removeTyping();
        const fallbacks = {
            'quote': "I'd love to help you get a quote! 🏗️\n\nPlease share:\n1. Project type (residential/commercial/industrial)\n2. Location & size\n3. Budget range\n4. Timeline\n\nOr call us: +1 234 567 890",
            'service': "We offer: 🏠 Residential · 🏢 Commercial · 🏭 Industrial · 🌿 Landscape · 🔧 Renovations · 🖥️ Digital Twin/BIM\n\nWhich service interests you?",
            'contact': "📞 +1 234 567 890\n✉️ info@riselium.com\n📍 123 Dream Street, Hyderabad\n🕐 Mon–Sat, 9AM–7PM",
            'project': "We've delivered 100+ projects! 🏗️ Check our Projects section to browse by type — residential, commercial, industrial & landscape."
        };
        const lower = text.toLowerCase();
        let reply = "Thanks for reaching out! 😊 I'm here to help with quotes, services, and project queries. What would you like to know?";
        for (const [k, v] of Object.entries(fallbacks)) { if (lower.includes(k)) { reply = v; break; } }
        addMsg('bot', reply);
        conversationHistory.push({ role: 'assistant', content: reply });
    }
}
</script>
