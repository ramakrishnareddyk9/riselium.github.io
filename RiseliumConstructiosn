        icon: '🏭', title: 'TechPark Manufacturing Hub', tag: 'Industrial', tagClass: 'badge-ind',
        desc: 'A purpose-built 85,000 sq.ft manufacturing facility for a leading electronics OEM. Features ISO Class 7 clean rooms, a 10MW solar rooftop, automated material handling systems, and real-time Digital Twin monitoring dashboards.',
        specs: [
            { label: 'Total Area', val: '85,000 sq.ft' },
            { label: 'Clean Rooms', val: 'ISO Class 7' },
            { label: 'Solar', val: '10 MW' },
